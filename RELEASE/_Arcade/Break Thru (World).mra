	<!-- DIP switches (brkthru): delivered to status[16+] and read by the core
	     (BreakThru.sv dsw1_bus/dsw2_bus). base 16: DSW1=bits0-7, DSW2=bits8-12.
	     default 7f,1f = Coin 1C/1C, slow, 1-player upright, 3 lives, 20k/30k. -->
	<switches default="7f,1f" base="16">
		<dip name="Coin A"   bits="0,1" ids="2C/1C,1C/3C,1C/2C,1C/1C"/>
		<dip name="Coin B"   bits="2,3" ids="2C/1C,1C/3C,1C/2C,1C/1C"/>
		<dip name="Enemy Vehicles" bits="4" ids="Fast,Slow"/>
		<dip name="Enemy Bullets"  bits="5" ids="Fast,Slow"/>
		<dip name="Control Panel"  bits="6" ids="2 Players,1 Player"/>
		<dip name="Cabinet"        bits="7" ids="Upright,Cocktail"/>
		<dip name="Lives"      bits="8,9"   ids="99 (Cheat),5,2,3"/>
		<dip name="Bonus Life" bits="10,11" ids="20k Only,10k/20k,20k/40k,20k/30k"/>
		<dip name="Service Mode" bits="12" ids="Off,On"/>
	</switches>
</misterromdescription>
